{
  "name": "billpro-billing-system",
  "version": "1.0.0",
  "description": "Premium Desktop Billing System with Product Images",
  "author": "Your Company Name",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build": "npm run rebuild && electron-builder",
    "postinstall": "npm run rebuild"
  },
  "dependencies": {
    "better-sqlite3": "9.6.0"
  },
  "devDependencies": {
    "@electron/rebuild": "3.6.0",
    "electron": "28.3.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.billpro.billing",
    "productName": "BillPro Billing System",
    "copyright": "Copyright © 2024 Your Company Name",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BillPro",
      "artifactName": "BillPro-Setup-${version}.exe"
    }
  }
}